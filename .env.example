# -----------------------------------------------------------------------------
# VidyAI Environment Variables Template
# Copy this file to .env and fill in the values for local development.
# -----------------------------------------------------------------------------

# PostgreSQL Database Connection String
# Compatible with Neon, Supabase, Vercel Postgres, etc.
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Google Gemini API Key
# IMPORTANT: Use ONLY the server-side key below. Never expose the API key to the client.
# The /api/gemini route handles all Gemini requests server-side for security.
GEMINI_API_KEY="your-gemini-api-key-here"
# DEPRECATED: Do NOT use NEXT_PUBLIC_GEMINI_API_KEY. It exposes your API key to the client.
# NEXT_PUBLIC_GEMINI_API_KEY="your-gemini-api-key-here"

# Groq API Key
# IMPORTANT: Use ONLY the server-side key below. Never expose the API key to the client.
# The /api/groq route handles all Groq requests server-side for security.
GROQ_API_KEY="your-groq-api-key-here"
# DEPRECATED: Do NOT use NEXT_PUBLIC_GROQ_API_KEY. It exposes your API key to the client.
# NEXT_PUBLIC_GROQ_API_KEY="your-groq-api-key-here"
