# -----------------------------------------------------------------------------
# VidyAI Environment Variables Template
# Copy this file to .env and fill in the values for local development.
# -----------------------------------------------------------------------------

# PostgreSQL Database Connection String
# Compatible with Neon, Supabase, Vercel Postgres, etc.
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Google Gemini API Key
# (Recommended) Secure server-only API key for tutoring and content generation features
GEMINI_API_KEY="your-gemini-api-key-here"
# (Legacy Fallback) Frontend-exposed API key (use only if required by client context)
NEXT_PUBLIC_GEMINI_API_KEY="your-gemini-api-key-here"

# Groq API Key
# (Recommended) Secure server-only API key for Groq API route endpoints
GROQ_API_KEY="your-groq-api-key-here"
# (Legacy Fallback) Frontend-exposed API key (use only if required by client context)
NEXT_PUBLIC_GROQ_API_KEY="your-groq-api-key-here"
